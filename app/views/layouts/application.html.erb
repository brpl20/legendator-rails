<!DOCTYPE html>
<html class="h-full">
  <head>
    <title><%= content_for(:title) || "Legendator" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Legendator">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;500;600;700;800;900&family=Rajdhani:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    <style>
      :root {
        --toku-red: #e11d48;
        --toku-gold: #FEBB12;
        --toku-silver: #cbd5e1;
        --toku-dark: #0c0a1a;
        --toku-dark-mid: #1a1033;
        --toku-purple: #7c3aed;
        --toku-blue: #2563eb;
      }


      body.toku-body {
        font-family: 'Rajdhani', sans-serif;
        background: var(--toku-dark);
        overflow-x: hidden;
      }

      /* Hero section */
      .hero-section { position: relative; }

      /* Grid texture background */
      .hero-grid-bg {
        position: absolute;
        inset: 0;
        background-image:
          linear-gradient(rgba(124, 58, 237, 0.07) 1px, transparent 1px),
          linear-gradient(90deg, rgba(124, 58, 237, 0.07) 1px, transparent 1px);
        background-size: 60px 60px;
        mask-image: radial-gradient(ellipse 80% 70% at 50% 40%, black 20%, transparent 70%);
        -webkit-mask-image: radial-gradient(ellipse 80% 70% at 50% 40%, black 20%, transparent 70%);
        pointer-events: none;
      }

      /* Radial glows */
      .hero-glow {
        position: absolute;
        border-radius: 50%;
        filter: blur(80px);
        pointer-events: none;
        opacity: 0.4;
      }
      .hero-glow--purple {
        width: 500px; height: 500px;
        top: -100px; left: 50%;
        transform: translateX(-50%);
        background: radial-gradient(circle, rgba(124, 58, 237, 0.35), transparent 70%);
      }
      .hero-glow--red {
        width: 350px; height: 350px;
        bottom: -50px; right: 10%;
        background: radial-gradient(circle, rgba(225, 29, 72, 0.2), transparent 70%);
      }

      /* Hero highlight text */
      .hero-highlight {
        background: linear-gradient(135deg, var(--toku-gold), #fbbf24);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }

      /* Hero badges */
      .hero-badge {
        display: inline-flex;
        align-items: center;
        padding: 4px 12px;
        font-size: 0.75rem;
        font-weight: 600;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        color: var(--toku-silver);
        border: 1px solid rgba(124, 58, 237, 0.3);
        border-radius: 9999px;
        background: rgba(124, 58, 237, 0.08);
      }

      /* Section divider */
      .section-divider {
        height: 1px;
        width: 100vw;
        margin-left: calc(-50vw + 50%);
        background: linear-gradient(90deg, transparent, rgba(124, 58, 237, 0.4), var(--toku-gold), rgba(124, 58, 237, 0.4), transparent);
      }

      /* Section underline */
      .section-underline {
        width: 60px;
        height: 3px;
        border-radius: 2px;
        background: linear-gradient(90deg, var(--toku-gold), var(--toku-red));
      }

      /* Como Funciona - full width breakout */
      .como-funciona-section {
        position: relative;
        width: 100vw;
        margin-left: calc(-50vw + 50%);
        padding-left: 1.5rem;
        padding-right: 1.5rem;
        background:
          radial-gradient(ellipse 60% 50% at 20% 50%, rgba(124, 58, 237, 0.08), transparent),
          radial-gradient(ellipse 60% 50% at 80% 50%, rgba(225, 29, 72, 0.05), transparent),
          linear-gradient(180deg, rgba(26, 16, 51, 0.6) 0%, rgba(16, 12, 32, 1) 50%, rgba(26, 16, 51, 0.6) 100%);
      }
      .como-funciona-section > * {
        max-width: 64rem;
        margin-left: auto;
        margin-right: auto;
      }

      /* Step label */
      .step-label {
        font-family: 'Orbitron', sans-serif;
        font-size: 0.65rem;
        font-weight: 700;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: var(--toku-gold);
        opacity: 0.6;
        margin-bottom: 0.75rem;
      }

      /* Preço section - full width */
      .preco-section {
        width: 100vw;
        margin-left: calc(-50vw + 50%);
        padding-left: 1.5rem;
        padding-right: 1.5rem;
        background:
          radial-gradient(ellipse 50% 60% at 50% 40%, rgba(225, 29, 72, 0.05), transparent),
          linear-gradient(180deg, rgba(26, 16, 51, 0.4) 0%, rgba(12, 10, 26, 1) 50%, rgba(26, 16, 51, 0.4) 100%);
      }
      .preco-section > * {
        max-width: 64rem;
        margin-left: auto;
        margin-right: auto;
      }

      /* Footer */
      .footer-section {
        width: 100vw;
        margin-left: calc(-50vw + 50%);
        padding-left: 1.5rem;
        padding-right: 1.5rem;
      }

      /* Starburst lines background */
      .starburst {
        position: relative;
        overflow: hidden;
      }
      .starburst::before {
        content: '';
        position: absolute;
        inset: 0;
        background:
          repeating-conic-gradient(
            from 0deg at 50% 120%,
            rgba(124, 58, 237, 0.06) 0deg 5deg,
            transparent 5deg 10deg
          );
        pointer-events: none;
      }

      /* Logo video banner */
      .logo-banner {
        position: relative;
        border: 3px solid transparent;
        background-clip: padding-box;
        overflow: hidden;
      }
      .logo-banner::before {
        content: '';
        position: absolute;
        inset: -3px;
        background: linear-gradient(135deg, var(--toku-red), var(--toku-gold), var(--toku-red), var(--toku-purple));
        background-size: 300% 300%;
        animation: borderShift 4s ease-in-out infinite;
        z-index: -1;
        border-radius: inherit;
      }
      @keyframes borderShift {
        0%, 100% { background-position: 0% 50%; }
        50% { background-position: 100% 50%; }
      }

      /* Card hover effect */
      .toku-card {
        position: relative;
        background: linear-gradient(135deg, rgba(26, 16, 51, 0.9), rgba(12, 10, 26, 0.95));
        border: 1px solid rgba(124, 58, 237, 0.3);
        transition: all 0.3s ease;
      }
      .toku-card:hover {
        border-color: var(--toku-red);
        transform: translateY(-4px) scale(1.02);
        box-shadow:
          0 0 20px rgba(225, 29, 72, 0.2),
          0 20px 40px rgba(0, 0, 0, 0.4);
      }
      .toku-card::after {
        content: '';
        position: absolute;
        top: 0; left: 0;
        width: 100%;
        height: 2px;
        background: linear-gradient(90deg, transparent, var(--toku-gold), transparent);
        opacity: 0;
        transition: opacity 0.3s;
      }
      .toku-card:hover::after { opacity: 1; }

      /* Step number styling */
      .step-number {
        font-family: 'Orbitron', sans-serif;
        font-size: 2.5rem;
        line-height: 1;
        background: linear-gradient(180deg, var(--toku-gold) 0%, var(--toku-red) 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        filter: drop-shadow(0 0 8px rgba(245, 158, 11, 0.3));
      }

      /* Icon circle glow */
      .step-icon-circle {
        width: 72px;
        height: 72px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        background: radial-gradient(circle, rgba(254, 187, 18, 0.12) 0%, transparent 70%);
        border: 1px solid rgba(254, 187, 18, 0.25);
        transition: all 0.3s ease;
      }
      .toku-card:hover .step-icon-circle {
        border-color: rgba(254, 187, 18, 0.5);
        box-shadow: 0 0 20px rgba(254, 187, 18, 0.15);
      }

      /* Connector line between steps */
      .step-connector {
        position: relative;
      }
      .step-connector::after {
        content: '';
        position: absolute;
        top: 50%;
        right: -1rem;
        width: calc(2rem);
        height: 2px;
        background: linear-gradient(90deg, rgba(124, 58, 237, 0.4), rgba(254, 187, 18, 0.3));
        transform: translateY(-50%);
      }
      @media (max-width: 639px) {
        .step-connector::after { display: none; }
      }

      /* CTA button */
      .toku-btn-primary {
        position: relative;
        background: #D90E3D;
        overflow: hidden;
        transition: all 0.3s ease;
        box-shadow: 0 0 40px rgba(217, 14, 61, 0.5);
      }
      .toku-btn-primary:hover {
        background: #c00c36;
      }

      .toku-btn-secondary {
        border: 1px solid rgba(254, 187, 18, 0.4);
        color: var(--toku-gold);
        background: rgba(12, 10, 26, 0.6);
        position: relative;
        box-shadow: 0 1px 2px rgba(0, 0, 0, 0.1);
        transition: all 0.3s ease;
      }
      .toku-btn-secondary:hover {
        border-color: var(--toku-gold);
        background: rgba(254, 187, 18, 0.08);
        box-shadow: 0 0 20px rgba(254, 187, 18, 0.15);
      }
      /* Entrance animations */
      @keyframes slideUp {
        from { opacity: 0; transform: translateY(40px); }
        to { opacity: 1; transform: translateY(0); }
      }
      @keyframes scaleIn {
        from { opacity: 0; transform: scale(0.8); }
        to { opacity: 1; transform: scale(1); }
      }
      @keyframes fadeIn {
        from { opacity: 0; }
        to { opacity: 1; }
      }
      .anim-slide-up {
        animation: slideUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        opacity: 0;
      }
      .anim-scale-in {
        animation: scaleIn 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        opacity: 0;
      }
      .anim-fade-in {
        animation: fadeIn 0.6s ease forwards;
        opacity: 0;
      }
      .delay-1 { animation-delay: 0.15s; }
      .delay-2 { animation-delay: 0.3s; }
      .delay-3 { animation-delay: 0.45s; }
      .delay-4 { animation-delay: 0.6s; }
      .delay-5 { animation-delay: 0.75s; }

      /* Decorative corner brackets */
      .corner-brackets {
        position: relative;
      }
      .corner-brackets::before,
      .corner-brackets::after {
        content: '';
        position: absolute;
        width: 20px;
        height: 20px;
        border-color: var(--toku-gold);
        opacity: 0.5;
      }
      .corner-brackets::before {
        top: -4px; left: -4px;
        border-top: 2px solid;
        border-left: 2px solid;
      }
      .corner-brackets::after {
        bottom: -4px; right: -4px;
        border-bottom: 2px solid;
        border-right: 2px solid;
      }

      /* Nav styling */
      .toku-nav {
        position: sticky;
        top: 0;
        z-index: 50;
        background: linear-gradient(180deg, rgba(12, 10, 26, 0.97), rgba(12, 10, 26, 0.9));
        border-bottom: 1px solid rgba(124, 58, 237, 0.15);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
      }
      .toku-nav-brand {
        font-family: 'Orbitron', sans-serif;
        font-weight: 700;
        background: linear-gradient(135deg, var(--toku-gold), #fbbf24, var(--toku-gold));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        filter: drop-shadow(0 0 6px rgba(245, 158, 11, 0.4));
      }
      .toku-nav-link {
        color: var(--toku-silver);
        position: relative;
        padding-bottom: 2px;
        transition: color 0.3s;
      }
      .toku-nav-link::after {
        content: '';
        position: absolute;
        bottom: 0;
        left: 0;
        width: 0;
        height: 1px;
        background: var(--toku-gold);
        transition: width 0.3s;
      }
      .toku-nav-link:hover {
        color: #fff;
      }
      .toku-nav-link:hover::after {
        width: 100%;
      }

      /* Desktop nav links */
      .nav-desktop { display: flex; }

      /* Mobile hamburger */
      .nav-hamburger { display: none; cursor: pointer; }
      .nav-hamburger span {
        display: block;
        width: 22px;
        height: 2px;
        background: var(--toku-silver);
        border-radius: 2px;
        transition: all 0.3s ease;
      }
      .nav-hamburger span:nth-child(2) { margin: 5px 0; }
      .nav-hamburger.active span:nth-child(1) { transform: rotate(45deg) translate(5px, 5px); }
      .nav-hamburger.active span:nth-child(2) { opacity: 0; }
      .nav-hamburger.active span:nth-child(3) { transform: rotate(-45deg) translate(5px, -5px); }

      /* Mobile menu */
      .nav-mobile-menu {
        display: none;
        position: absolute;
        top: 100%;
        left: 0;
        right: 0;
        background: rgba(12, 10, 26, 0.98);
        border-bottom: 1px solid rgba(124, 58, 237, 0.2);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        padding: 1rem 1.5rem 1.5rem;
        flex-direction: column;
        gap: 0.5rem;
        animation: slideDown 0.3s ease forwards;
      }
      .nav-mobile-menu.open { display: flex; }
      @keyframes slideDown {
        from { opacity: 0; transform: translateY(-8px); }
        to { opacity: 1; transform: translateY(0); }
      }
      .nav-mobile-menu a {
        padding: 0.75rem 0;
        border-bottom: 1px solid rgba(124, 58, 237, 0.1);
      }

      /* CTA in mobile menu */
      .nav-mobile-cta {
        margin-top: 0.5rem;
        text-align: center;
      }

      /* Hide desktop on mobile */
      @media (max-width: 639px) {
        .nav-desktop { display: none; }
        .nav-hamburger { display: flex; flex-direction: column; gap: 0; }
        .nav-cta-desktop { display: none; }
      }
    </style>
  </head>

  <body class="min-h-full toku-body text-slate-100 antialiased">
    <nav class="toku-nav">
      <div class="mx-auto max-w-5xl flex items-center justify-between px-6 py-4">
        <!-- Brand -->
        <%= link_to root_path, class: "toku-nav-brand text-xl tracking-wider hover:opacity-80 transition" do %>
          LEGENDATOR
        <% end %>

        <!-- Desktop links -->
        <div class="nav-desktop items-center gap-6">
          <a href="#como-funciona" class="toku-nav-link tracking-wider text-sm font-semibold">Como Funciona</a>
          <a href="#preco" class="toku-nav-link tracking-wider text-sm font-semibold">Preço</a>
        </div>

        <!-- Desktop CTA -->
        <div class="nav-cta-desktop">
          <%= link_to new_translation_path,
              class: "group toku-btn-primary inline-flex items-center rounded-lg px-4 py-2.5 text-sm font-bold text-white tracking-wider uppercase" do %>
            <svg class="mr-2 w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z"/><path d="M20 3v4"/><path d="M22 5h-4"/></svg>
            Traduzir Agora
          <% end %>
        </div>

        <!-- Mobile hamburger -->
        <div class="nav-hamburger" onclick="this.classList.toggle('active'); document.getElementById('mobileMenu').classList.toggle('open');">
          <span></span>
          <span></span>
          <span></span>
        </div>
      </div>

      <!-- Mobile menu -->
      <div id="mobileMenu" class="nav-mobile-menu">
        <a href="#como-funciona" class="toku-nav-link tracking-wider text-lg font-semibold" onclick="document.getElementById('mobileMenu').classList.remove('open'); document.querySelector('.nav-hamburger').classList.remove('active');">Como Funciona</a>
        <a href="#preco" class="toku-nav-link tracking-wider text-lg font-semibold" onclick="document.getElementById('mobileMenu').classList.remove('open'); document.querySelector('.nav-hamburger').classList.remove('active');">Preço</a>
        <div class="nav-mobile-cta">
          <%= link_to new_translation_path,
              class: "group toku-btn-primary inline-flex items-center justify-center rounded-lg px-6 py-3 text-sm font-bold text-white tracking-wider uppercase w-full" do %>
            <svg class="mr-2 w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z"/><path d="M20 3v4"/><path d="M22 5h-4"/></svg>
            Traduzir Agora
          <% end %>
        </div>
      </div>
    </nav>

    <% if flash[:notice] %>
      <div class="mx-auto max-w-5xl px-6 mt-4">
        <div class="rounded-lg bg-emerald-900/50 border border-emerald-700 px-4 py-3 text-emerald-200 text-sm">
          <%= flash[:notice] %>
        </div>
      </div>
    <% end %>

    <% if flash[:alert] %>
      <div class="mx-auto max-w-5xl px-6 mt-4">
        <div class="rounded-lg bg-red-900/50 border border-red-700 px-4 py-3 text-red-200 text-sm">
          <%= flash[:alert] %>
        </div>
      </div>
    <% end %>

    <main class="mx-auto max-w-5xl px-6 py-10">
      <%= yield %>
    </main>
  </body>
</html>

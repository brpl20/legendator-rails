<!DOCTYPE html>
<html class="h-full">
  <head>
    <title><%= content_for(:title) || "Legendator" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Legendator">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-full bg-slate-900 text-slate-100 antialiased">
    <nav class="border-b border-slate-800 bg-slate-950/60 backdrop-blur">
      <div class="mx-auto max-w-5xl flex items-center justify-between px-6 py-4">
        <%= link_to root_path, class: "text-xl font-bold tracking-tight text-white hover:text-emerald-400 transition" do %>
          Legendator
        <% end %>
        <%= link_to "Traduzir", new_translation_path, class: "text-sm font-medium text-slate-300 hover:text-white transition" %>
      </div>
    </nav>

    <% if flash[:notice] %>
      <div class="mx-auto max-w-5xl px-6 mt-4">
        <div class="rounded-lg bg-emerald-900/50 border border-emerald-700 px-4 py-3 text-emerald-200 text-sm">
          <%= flash[:notice] %>
        </div>
      </div>
    <% end %>

    <% if flash[:alert] %>
      <div class="mx-auto max-w-5xl px-6 mt-4">
        <div class="rounded-lg bg-red-900/50 border border-red-700 px-4 py-3 text-red-200 text-sm">
          <%= flash[:alert] %>
        </div>
      </div>
    <% end %>

    <main class="mx-auto max-w-5xl px-6 py-10">
      <%= yield %>
    </main>
  </body>
</html>

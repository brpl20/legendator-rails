<!DOCTYPE html>
<html class="h-full">
  <head>
    <title><%= content_for(:title) || "Legendator" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Legendator">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Black+Han+Sans&family=Dela+Gothic+One&family=Zen+Dots&family=Sawarabi+Gothic&display=swap" rel="stylesheet">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    <style>
      :root {
        --toku-red: #e11d48;
        --toku-gold: #f59e0b;
        --toku-silver: #cbd5e1;
        --toku-dark: #0c0a1a;
        --toku-dark-mid: #1a1033;
        --toku-purple: #7c3aed;
        --toku-blue: #2563eb;
      }

      .font-tokusatsu { font-family: 'Black Han Sans', sans-serif; }
      .font-hero { font-family: 'Dela Gothic One', sans-serif; }
      .font-cyber { font-family: 'Zen Dots', sans-serif; }
      .font-body { font-family: 'Sawarabi Gothic', sans-serif; }

      body.toku-body {
        background: var(--toku-dark);
        background-image:
          radial-gradient(ellipse at 20% 0%, rgba(124, 58, 237, 0.15) 0%, transparent 50%),
          radial-gradient(ellipse at 80% 100%, rgba(225, 29, 72, 0.1) 0%, transparent 50%);
      }

      /* Starburst lines background */
      .starburst {
        position: relative;
        overflow: hidden;
      }
      .starburst::before {
        content: '';
        position: absolute;
        inset: 0;
        background:
          repeating-conic-gradient(
            from 0deg at 50% 120%,
            rgba(124, 58, 237, 0.06) 0deg 5deg,
            transparent 5deg 10deg
          );
        pointer-events: none;
      }

      /* Speed lines */
      .speed-lines {
        position: relative;
      }
      .speed-lines::after {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0; bottom: 0;
        background:
          repeating-linear-gradient(
            90deg,
            transparent,
            transparent 48%,
            rgba(245, 158, 11, 0.03) 48%,
            rgba(245, 158, 11, 0.03) 48.5%,
            transparent 48.5%,
            transparent 100%
          );
        pointer-events: none;
      }

      /* Glowing text */
      .text-glow-red {
        text-shadow:
          0 0 10px rgba(225, 29, 72, 0.5),
          0 0 40px rgba(225, 29, 72, 0.3),
          0 0 80px rgba(225, 29, 72, 0.1);
      }
      .text-glow-gold {
        text-shadow:
          0 0 10px rgba(245, 158, 11, 0.6),
          0 0 30px rgba(245, 158, 11, 0.3);
      }

      /* Diagonal slash decoration */
      .slash-decoration {
        position: relative;
      }
      .slash-decoration::before,
      .slash-decoration::after {
        content: '';
        position: absolute;
        width: 120px;
        height: 3px;
        background: linear-gradient(90deg, transparent, var(--toku-red), transparent);
        top: 50%;
      }
      .slash-decoration::before { right: 100%; margin-right: 20px; transform: rotate(-5deg); }
      .slash-decoration::after { left: 100%; margin-left: 20px; transform: rotate(5deg); }

      /* Logo video banner */
      .logo-banner {
        position: relative;
        border: 3px solid transparent;
        background-clip: padding-box;
        overflow: hidden;
      }
      .logo-banner::before {
        content: '';
        position: absolute;
        inset: -3px;
        background: linear-gradient(135deg, var(--toku-red), var(--toku-gold), var(--toku-red), var(--toku-purple));
        background-size: 300% 300%;
        animation: borderShift 4s ease-in-out infinite;
        z-index: -1;
        border-radius: inherit;
      }
      @keyframes borderShift {
        0%, 100% { background-position: 0% 50%; }
        50% { background-position: 100% 50%; }
      }

      /* Card hover effect */
      .toku-card {
        position: relative;
        background: linear-gradient(135deg, rgba(26, 16, 51, 0.9), rgba(12, 10, 26, 0.95));
        border: 1px solid rgba(124, 58, 237, 0.3);
        transition: all 0.3s ease;
      }
      .toku-card:hover {
        border-color: var(--toku-red);
        transform: translateY(-4px) scale(1.02);
        box-shadow:
          0 0 20px rgba(225, 29, 72, 0.2),
          0 20px 40px rgba(0, 0, 0, 0.4);
      }
      .toku-card::after {
        content: '';
        position: absolute;
        top: 0; left: 0;
        width: 100%;
        height: 2px;
        background: linear-gradient(90deg, transparent, var(--toku-gold), transparent);
        opacity: 0;
        transition: opacity 0.3s;
      }
      .toku-card:hover::after { opacity: 1; }

      /* Step number styling */
      .step-number {
        font-family: 'Black Han Sans', sans-serif;
        font-size: 3.5rem;
        line-height: 1;
        background: linear-gradient(180deg, var(--toku-gold) 0%, var(--toku-red) 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        filter: drop-shadow(0 0 8px rgba(245, 158, 11, 0.3));
      }

      /* CTA button */
      .toku-btn-primary {
        position: relative;
        background: linear-gradient(135deg, var(--toku-red) 0%, #be123c 100%);
        overflow: hidden;
        transition: all 0.3s ease;
        box-shadow: 0 0 20px rgba(225, 29, 72, 0.3), inset 0 1px 0 rgba(255,255,255,0.1);
      }
      .toku-btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 0 30px rgba(225, 29, 72, 0.5), 0 8px 25px rgba(0,0,0,0.3);
      }
      .toku-btn-primary::before {
        content: '';
        position: absolute;
        top: -50%; left: -50%;
        width: 200%; height: 200%;
        background: linear-gradient(45deg, transparent 40%, rgba(255,255,255,0.1) 50%, transparent 60%);
        animation: sheen 3s ease-in-out infinite;
      }
      @keyframes sheen {
        0%, 100% { transform: translateX(-100%) rotate(45deg); }
        50% { transform: translateX(100%) rotate(45deg); }
      }

      .toku-btn-secondary {
        border: 1px solid rgba(245, 158, 11, 0.5);
        color: var(--toku-gold);
        transition: all 0.3s ease;
        position: relative;
      }
      .toku-btn-secondary:hover {
        background: rgba(245, 158, 11, 0.1);
        border-color: var(--toku-gold);
        box-shadow: 0 0 15px rgba(245, 158, 11, 0.2);
        transform: translateY(-2px);
      }

      /* Entrance animations */
      @keyframes slideUp {
        from { opacity: 0; transform: translateY(40px); }
        to { opacity: 1; transform: translateY(0); }
      }
      @keyframes scaleIn {
        from { opacity: 0; transform: scale(0.8); }
        to { opacity: 1; transform: scale(1); }
      }
      @keyframes fadeIn {
        from { opacity: 0; }
        to { opacity: 1; }
      }
      .anim-slide-up {
        animation: slideUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        opacity: 0;
      }
      .anim-scale-in {
        animation: scaleIn 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        opacity: 0;
      }
      .anim-fade-in {
        animation: fadeIn 0.6s ease forwards;
        opacity: 0;
      }
      .delay-1 { animation-delay: 0.15s; }
      .delay-2 { animation-delay: 0.3s; }
      .delay-3 { animation-delay: 0.45s; }
      .delay-4 { animation-delay: 0.6s; }
      .delay-5 { animation-delay: 0.75s; }

      /* Decorative corner brackets */
      .corner-brackets {
        position: relative;
      }
      .corner-brackets::before,
      .corner-brackets::after {
        content: '';
        position: absolute;
        width: 20px;
        height: 20px;
        border-color: var(--toku-gold);
        opacity: 0.5;
      }
      .corner-brackets::before {
        top: -4px; left: -4px;
        border-top: 2px solid;
        border-left: 2px solid;
      }
      .corner-brackets::after {
        bottom: -4px; right: -4px;
        border-bottom: 2px solid;
        border-right: 2px solid;
      }

      /* Nav styling */
      .toku-nav {
        background: linear-gradient(180deg, rgba(12, 10, 26, 0.95), rgba(12, 10, 26, 0.8));
        border-bottom: 1px solid rgba(124, 58, 237, 0.2);
        backdrop-filter: blur(12px);
      }
      .toku-nav-brand {
        font-family: 'Dela Gothic One', sans-serif;
        background: linear-gradient(135deg, var(--toku-gold), #fbbf24, var(--toku-gold));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        filter: drop-shadow(0 0 6px rgba(245, 158, 11, 0.4));
      }
    </style>
  </head>

  <body class="min-h-full toku-body text-slate-100 antialiased font-body">
    <nav class="toku-nav">
      <div class="mx-auto max-w-5xl flex items-center justify-between px-6 py-4">
        <%= link_to root_path, class: "toku-nav-brand text-xl tracking-wider hover:opacity-80 transition" do %>
          LEGENDATOR
        <% end %>
        <%= link_to "TRADUZIR", new_translation_path, class: "text-xl font-medium text-slate-300 hover:text-white transition tracking-wider uppercase", style: "font-family: 'Dela Gothic One', sans-serif;" %>
      </div>
    </nav>

    <% if flash[:notice] %>
      <div class="mx-auto max-w-5xl px-6 mt-4">
        <div class="rounded-lg bg-emerald-900/50 border border-emerald-700 px-4 py-3 text-emerald-200 text-sm">
          <%= flash[:notice] %>
        </div>
      </div>
    <% end %>

    <% if flash[:alert] %>
      <div class="mx-auto max-w-5xl px-6 mt-4">
        <div class="rounded-lg bg-red-900/50 border border-red-700 px-4 py-3 text-red-200 text-sm">
          <%= flash[:alert] %>
        </div>
      </div>
    <% end %>

    <main class="mx-auto max-w-5xl px-6 py-10">
      <%= yield %>
    </main>
  </body>
</html>

<div class="max-w-xl mx-auto">
  <div class="text-center mb-10">
    <p class="font-cyber text-xs tracking-widest uppercase mb-2"
       style="color: var(--toku-gold);">
      &#x2501;&#x2501; Nova Traducao &#x2501;&#x2501;
    </p>
    <h1 class="font-hero text-3xl text-white text-glow-red">Traduzir Legenda</h1>
    <p class="mt-3 text-base" style="color: var(--toku-silver);">Envie seu arquivo .srt (max 5MB) e escolha as opcoes de traducao.</p>
  </div>

  <div class="toku-card rounded-xl p-8">
    <%= form_with(model: @translation, class: "space-y-6", id: "translation-form") do |f| %>
      <% if @translation.errors.any? %>
        <div class="rounded-lg px-4 py-3 text-sm" style="background: rgba(225, 29, 72, 0.15); border: 1px solid var(--toku-red); color: #fca5a5;">
          <ul class="list-disc list-inside space-y-1">
            <% @translation.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div>
        <%= f.label :original_file, "Arquivo SRT", class: "block text-sm font-tokusatsu tracking-wider mb-2", style: "color: var(--toku-gold);" %>
        <%= f.file_field :original_file,
            accept: ".srt",
            id: "file-input",
            class: "hidden",
            style: "color: var(--toku-silver);" %>
        <div id="file-drop-zone" class="mt-2 rounded-lg px-4 py-3 text-center cursor-pointer transition"
             style="border: 2px dashed rgba(124, 58, 237, 0.4); background: rgba(124, 58, 237, 0.05);"
             onclick="document.getElementById('file-input').click()">
          <p id="file-drop-text" class="text-sm" style="color: var(--toku-silver);">Clique ou arraste seu arquivo <code class="font-mono text-xs px-1 py-0.5 rounded" style="background: rgba(124, 58, 237, 0.2); color: var(--toku-gold);">.srt</code></p>
        </div>
      </div>

      <div>
        <%= f.label :target_language, "Idioma de destino", class: "block text-sm font-tokusatsu tracking-wider mb-2", style: "color: var(--toku-gold);" %>
        <%= f.select :target_language,
            Translation::SUPPORTED_LANGUAGES.map { |k, v| [v, k] },
            { prompt: "Selecione o idioma" },
            class: "block w-full rounded-lg px-4 py-2.5 text-base transition",
            style: "background: var(--toku-dark); border: 1px solid rgba(124, 58, 237, 0.3); color: var(--toku-silver);" %>
      </div>

      <div>
        <%= f.label :model_used, "Modelo de IA", class: "block text-sm font-tokusatsu tracking-wider mb-2", style: "color: var(--toku-gold);" %>
        <%= f.select :model_used,
            Translation::AVAILABLE_MODELS.map { |k, v| [v, k] },
            {},
            class: "block w-full rounded-lg px-4 py-2.5 text-base transition",
            style: "background: var(--toku-dark); border: 1px solid rgba(124, 58, 237, 0.3); color: var(--toku-silver);" %>
      </div>

      <div class="pt-2">
        <p id="file-warning" class="text-sm mb-3 text-center" style="color: var(--toku-gold);">
          Envie um arquivo antes para comecar
        </p>
        <%= f.submit "Continuar para pagamento",
            id: "submit-btn",
            disabled: true,
            class: "toku-btn-primary w-full rounded-lg px-6 py-3 text-base font-tokusatsu text-white tracking-wider uppercase cursor-pointer disabled:opacity-40 disabled:cursor-not-allowed" %>
      </div>
    <% end %>
  </div>
</div>

<script>
  (function() {
    const fileInput = document.getElementById("file-input");
    const submitBtn = document.getElementById("submit-btn");
    const warning = document.getElementById("file-warning");
    const dropZone = document.getElementById("file-drop-zone");
    const dropText = document.getElementById("file-drop-text");

    if (!fileInput || !submitBtn) return;

    function updateUI() {
      if (fileInput.files.length > 0) {
        submitBtn.disabled = false;
        warning.style.display = "none";
        dropZone.style.borderColor = "var(--toku-gold)";
        dropZone.style.background = "rgba(245, 158, 11, 0.08)";
        dropText.innerHTML = '<strong style="color: var(--toku-gold);">' + fileInput.files[0].name + '</strong>';
      } else {
        submitBtn.disabled = true;
        warning.style.display = "block";
        dropZone.style.borderColor = "rgba(124, 58, 237, 0.4)";
        dropZone.style.background = "rgba(124, 58, 237, 0.05)";
        dropText.innerHTML = 'Clique ou arraste seu arquivo <code class="font-mono text-xs px-1 py-0.5 rounded" style="background: rgba(124, 58, 237, 0.2); color: var(--toku-gold);">.srt</code>';
      }
    }

    fileInput.addEventListener("change", updateUI);

    dropZone.addEventListener("dragover", function(e) {
      e.preventDefault();
      dropZone.style.borderColor = "var(--toku-gold)";
      dropZone.style.background = "rgba(245, 158, 11, 0.12)";
    });

    dropZone.addEventListener("dragleave", function(e) {
      e.preventDefault();
      if (!fileInput.files.length) {
        dropZone.style.borderColor = "rgba(124, 58, 237, 0.4)";
        dropZone.style.background = "rgba(124, 58, 237, 0.05)";
      }
    });

    dropZone.addEventListener("drop", function(e) {
      e.preventDefault();
      if (e.dataTransfer.files.length > 0) {
        fileInput.files = e.dataTransfer.files;
        updateUI();
      }
    });
  })();
</script>

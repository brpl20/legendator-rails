<div class="max-w-md mx-auto text-center">
  <h1 class="text-3xl font-bold text-white mb-2">Recuperar Traducao</h1>
  <p class="text-slate-400 mb-8">Digite o codigo que aparece no seu extrato bancario ou que foi exibido apos o upload.</p>

  <% if flash[:alert] %>
    <div class="rounded-lg bg-red-900/50 border border-red-700 px-4 py-3 text-red-200 text-sm mb-6">
      <%= flash[:alert] %>
    </div>
  <% end %>

  <%= form_with url: recover_path, method: :post, class: "space-y-6" do |f| %>
    <div>
      <%= f.text_field :code,
          placeholder: "LEG-XXXXXX",
          class: "block w-full rounded-lg bg-slate-800 border border-slate-600 text-slate-200 px-6 py-4 text-center text-2xl font-mono tracking-widest placeholder-slate-600 focus:ring-emerald-500 focus:border-emerald-500" %>
    </div>

    <div>
      <%= f.submit "Buscar",
          class: "w-full rounded-lg bg-emerald-600 px-6 py-3 text-base font-semibold text-white shadow hover:bg-emerald-500 transition cursor-pointer" %>
    </div>
  <% end %>
</div>
